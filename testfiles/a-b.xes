<?xml version="1.0" encoding="UTF-8" ?>
<log xes.version="1.0">
  <extension name="Concept" prefix="concept" uri="http://code.deckfour.org/xes/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://code.deckfour.org/xes/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://code.deckfour.org/xes/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="name"/>
  </global>
  <classifier name="Activity" keys="Activity"/>
  <trace>
    <string key="concept:name" value="first trace"/>
    <int key="attribute" value="1"/>
    <event>
      <string key="concept:name" value="a"/>
      <string key="other_attribute" value="z"/>
      <date key="time:timestamp" value="2017-05-09T00:00:00.000+01:00"/>
      <string key="org:resource" value="John"/>
    </event>
  </trace>
  <trace>
    <string key="concept:name" value="second trace"/>
    <int key="attribute" value="2"/>
    <event>
      <string key="concept:name" value="b"/>
      <string key="other_attribute" value="y"/>
      <date key="time:timestamp" value="2017-05-09T00:00:00.000+01:00"/>
      <string key="org:resource" value="Doe"/>
    </event>
  </trace>
</log>
