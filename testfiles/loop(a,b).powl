{
  "format": "powl-json",
  "format_version": "1.0",
  "model": {
  	"type": "choice_graph",
  	"nodes": [
	  {
		    "id": "a",
		    "type": "activity",
		    "repeatable": false,
		    "skippable": false,
		    "label": "a"
	  },
	  {
		    "id": "b",
		    "type": "activity",
		    "repeatable": false,
		    "skippable": false,
		    "label": "b"
	  }
  	],
  	"edges": [
  		{ "source": "@start", "target": "a" },
  		{ "source": "a", "target": "b" },
  		{ "source": "b", "target": "a" },
  		{ "source": "a", "target": "@end" }
  	]
  }
}
